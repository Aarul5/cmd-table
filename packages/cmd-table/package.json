{
  "name": "cmd-table",
  "version": "1.5.2",
  "description": "CLI table library for Node.js with interactive terminal UI, streaming, CSV/JSON/HTML support, pivot tables, sparklines, and TypeScript. A modern alternative to cli-table3 and table.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "cmd-table": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "docs:dev": "vitepress dev ../../docs",
    "docs:build": "vitepress build ../../docs",
    "docs:preview": "vitepress preview ../../docs",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "cli",
    "table",
    "terminal",
    "console",
    "ascii",
    "unicode",
    "responsive",
    "layout",
    "stream",
    "data-visualization",
    "csv",
    "json",
    "markdown",
    "tree",
    "nested",
    "merge",
    "ansi",
    "pretty-print",
    "cli-table",
    "cli-table3",
    "command-line",
    "format",
    "formatter",
    "tui",
    "interactive",
    "sparkline",
    "heatmap",
    "pivot",
    "pivot-table",
    "sqlite",
    "sql",
    "zero-dependency",
    "lightweight",
    "typescript",
    "border",
    "box",
    "pagination",
    "sorting",
    "jsx",
    "react",
    "export"
  ],
  "author": {
    "name": "Arul",
    "url": "https://github.com/Aarul5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aarul5/cmd-table.git",
    "directory": "packages/cmd-table"
  },
  "bugs": {
    "url": "https://github.com/Aarul5/cmd-table/issues"
  },
  "homepage": "https://aarul5.github.io/cmd-table/",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "better-sqlite3": "^12.6.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.3.3",
    "vitepress": "^1.6.4",
    "vue": "^3.5.28"
  }
}
