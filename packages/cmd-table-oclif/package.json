{
  "name": "cmd-table-oclif",
  "version": "0.1.0",
  "description": "cmd-table integration for oclif CLI commands — drop-in replacement for cli-ux table",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "oclif",
    "cli",
    "table",
    "cmd-table",
    "cli-ux"
  ],
  "author": {
    "name": "Arul",
    "url": "https://github.com/Aarul5"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aarul5/cmd-table.git",
    "directory": "packages/cmd-table-oclif"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "cmd-table": "^1.5.0",
    "@oclif/core": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@oclif/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@oclif/core": "^4.0.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "cmd-table": "workspace:*",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsup": "^8.5.1",
    "typescript": "^5.3.3"
  }
}
